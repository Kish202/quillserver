PORT=3001
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:3001

# Neon Postgres connection string
DATABASE_URL=

# JWT signing secret (any long random string)
JWT_SECRET=long-random-string

# SEC EDGAR User-Agent — "Name email@domain" (avoid noreply/company-name patterns)
SEC_USER_AGENT="Quill Research you@example.com"

# Prod only: SEC blocks datacenter IPs (Render) — proxy SEC fetches through Vercel
# SEC_PROXY_BASE=https://quill-app-sec.vercel.app

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email via Brevo (HTTP API). EMAIL_FROM must be a Brevo-verified sender.
# No key locally → links log to the console.
EMAIL_FROM="Quill <you@gmail.com>"
# BREVO_API_KEY=
